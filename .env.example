TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_IDS=-1001234567890,-1009876543210
TELEGRAM_ADMIN_CHAT_ID=
LOG_LEVEL=INFO

POLL_INTERVAL_MINUTES=45
POLL_JITTER_SECONDS=600

QUIET_HOURS_START=01:00
QUIET_HOURS_END=06:00

BLOCK_COOLDOWN_HOURS=6
BLOCK_COOLDOWN_MAX_HOURS=48

# optional: force Playwright (recommended — API requires reCAPTCHA)
USE_PLAYWRIGHT=true
# Nếu token reCAPTCHA treo lâu: thử PLAYWRIGHT_HEADLESS=false (mở cửa sổ Chrome) hoặc PLAYWRIGHT_CHANNEL=chrome
PLAYWRIGHT_HEADLESS=true
# PLAYWRIGHT_CHANNEL=chrome

# Số gói mỗi lần cào = CRAWL_MAX_PAGES × CRAWL_PAGE_SIZE (tối đa 10×50=500)
# Mặc định 2×50=100. Tăng dần nếu cần; càng nhiều càng dễ bị chặn IP.
CRAWL_PAGE_SIZE=50
CRAWL_MAX_PAGES=5

# Bot tra nhanh: python -m tracker.bot_commands
INTERACTIVE_SEARCH_MAX_MESSAGES=15
INTERACTIVE_SEARCH_COOLDOWN_SECONDS=45
# true: /tim chỉ giữ gói mà từ khóa khớp cả từ (VD không lấy camera khi chỉ tìm cam). Cụm nhiều từ: khớp nguyên cụm.
INTERACTIVE_SEARCH_STRICT_KEYWORDS=true
# Tuỳ chọn: giới hạn số trang /tim mỗi cụm (vd. 3 = nhanh). Để trống = dùng CRAWL_MAX_PAGES.
# INTERACTIVE_CRAWL_MAX_PAGES=4
BOT_GROUP_FREEWORD=false
BOT_GROUP_REPLY_HINT=false
